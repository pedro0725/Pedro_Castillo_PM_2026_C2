using System;

class Program
{
    static void Main()
    {
        int opcion;
        int cantidadJugadas = 0;
        Random random = new Random();

        do
        {
            Console.WriteLine("\n===== LOTERIA =====");
            Console.WriteLine("1. Jugar");
            Console.WriteLine("2. Elegir cantidad de jugadas");
            Console.WriteLine("3. Salir");
            Console.Write("Seleccione una opción: ");

            opcion = Convert.ToInt32(Console.ReadLine());

            switch (opcion)
            {
                case 1:

                    if (cantidadJugadas <= 0)
                    {
                        Console.WriteLine("Debe elegir primero la cantidad de jugadas.");
                    }
                    else
                    {
                        double totalApostado = 0;

                        for (int i = 1; i <= cantidadJugadas; i++)
                        {
                            int numero;
                            double dinero;

                            Console.WriteLine($"\n===== Jugada #{i} =====");

                            do
                            {
                                Console.Write("Ingrese un número (1-40): ");
                                numero = Convert.ToInt32(Console.ReadLine());

                            } while (numero < 1 || numero > 40);

                            do
                            {
                                Console.Write("Ingrese el monto apostado: RD$");
                                dinero = Convert.ToDouble(Console.ReadLine());

                            } while (dinero <= 0);

                            totalApostado += dinero;

                            int numeroGanador = random.Next(1, 41);

                            Console.WriteLine("Número ganador: " + numeroGanador);

                            if (numero == numeroGanador)
                            {
                                double premio = dinero * 100;
                                Console.WriteLine("¡FELICIDADES, GANASTE!");
                                Console.WriteLine("Premio: RD$" + premio);
                            }
                            else
                            {
                                Console.WriteLine("Lo sentimos, no ganaste.");
                            }
                        }

                        Console.WriteLine("\nTotal apostado: RD$" + totalApostado);
                    }
                    break;

                case 2:

                    do
                    {
                        Console.Write("Ingrese la cantidad de jugadas: ");
                        cantidadJugadas = Convert.ToInt32(Console.ReadLine());

                    } while (cantidadJugadas <= 0);

                    Console.WriteLine("Cantidad de jugadas guardada.");
                    break;

                case 3:

                    Console.WriteLine("Gracias por utilizar el sistema.");
                    break;

                default:

                    Console.WriteLine("Opción inválida.");
                    break;
            }

        } while (opcion != 3);
    }
}

#include <stdio.h>
#include <string.h>

/* Cadenas invertidas y concatenadas. */

void main(void)
{
    char cad1[50], cad2[50], cad3[100];
    
    printf("Ingrese la primera cadena de caracteres: ");
    gets(cad1);
    printf("Ingrese la segunda cadena de caracteres: ");
    gets(cad2);
    
    strcpy(cad3, cad2); /* Copia cad2 en cad3 */
    strcat(cad3, " ");  /* Añade un espacio en blanco */
    strcat(cad3, cad1); /* Concatena cad1 al final de cad3 */
    
    printf("\nLa cadena resultante es: %s", cad3);
}
